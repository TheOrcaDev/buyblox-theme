</div>

<script>
(function() {
  'use strict';

  function createMcpSnowflakes() {
    const container = document.getElementById('mcpSnowflakes');
    if (!container) return;
    
    const snowflakes = ['❄', '❅', '❆', '✧', '✦'];
    const count = 30;
    
    for (let i = 0; i < count; i++) {
      const flake = document.createElement('span');
      flake.className = 'mcp-snowflake';
      flake.textContent = snowflakes[Math.floor(Math.random() * snowflakes.length)];
      flake.style.left = Math.random() * 100 + '%';
      flake.style.animationDuration = (Math.random() * 10 + 8) + 's';
      flake.style.animationDelay = (Math.random() * 15) + 's';
      flake.style.fontSize = (Math.random() * 0.8 + 0.5) + 'rem';
      flake.style.opacity = Math.random() * 0.4 + 0.2;
      container.appendChild(flake);
    }
  }
  
  createMcpSnowflakes();

  // Banner Carousel
  const bannerCarousel = document.getElementById('mcpBannerCarousel');
  if (bannerCarousel) {
    const track = document.getElementById('mcpBannerTrack');
    const slides = track ? track.querySelectorAll('.mcp-banner-slide') : [];
    const dots = document.querySelectorAll('.mcp-banner-dot');
    const prevBtn = document.getElementById('mcpBannerPrev');
    const nextBtn = document.getElementById('mcpBannerNext');
    const progress = document.getElementById('mcpBannerProgress');
    
    let currentSlide = 0;
    let autoplayInterval = null;
    let progressInterval = null;
    const autoplaySpeed = {{ section.settings.autoplay_speed | default: 8 }} * 1000;
    const slideCount = slides.length;
    
    function goToSlide(index) {
      if (index < 0) index = slideCount - 1;
      if (index >= slideCount) index = 0;
      currentSlide = index;
      
      if (track) {
        track.style.transform = `translateX(-${currentSlide * 100}%)`;
      }
      
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === currentSlide);
      });
      
      resetProgress();
    }
    
    function nextSlide() {
      goToSlide(currentSlide + 1);
    }
    
    function prevSlide() {
      goToSlide(currentSlide - 1);
    }
    
    function resetProgress() {
      if (progress) {
        progress.style.transition = 'none';
        progress.style.width = '0%';
        setTimeout(() => {
          progress.style.transition = `width ${autoplaySpeed}ms linear`;
          progress.style.width = '100%';
        }, 50);
      }
    }
    
    function startAutoplay() {
      stopAutoplay();
      if (slideCount > 1) {
        autoplayInterval = setInterval(nextSlide, autoplaySpeed);
        resetProgress();
      }
    }
    
    function stopAutoplay() {
      if (autoplayInterval) {
        clearInterval(autoplayInterval);
        autoplayInterval = null;
      }
      if (progress) {
        progress.style.transition = 'none';
        progress.style.width = '0%';
      }
    }
    
    if (prevBtn) prevBtn.addEventListener('click', () => { prevSlide(); startAutoplay(); });
    if (nextBtn) nextBtn.addEventListener('click', () => { nextSlide(); startAutoplay(); });
    
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => { goToSlide(i); startAutoplay(); });
    });
    
    bannerCarousel.addEventListener('mouseenter', stopAutoplay);
    bannerCarousel.addEventListener('mouseleave', startAutoplay);
    
    // Touch support
    let touchStartX = 0;
    let touchEndX = 0;
    
    bannerCarousel.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
      stopAutoplay();
    }, { passive: true });
    
    bannerCarousel.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) nextSlide();
        else prevSlide();
      }
      startAutoplay();
    }, { passive: true });
    
    if (slideCount > 1) {
      startAutoplay();
    }
  }

  const navTabs = document.querySelectorAll('.mcp-nav-tab');
  navTabs.forEach(tab => {
    tab.addEventListener('click', function(e) {
      e.preventDefault();
      const targetId = this.getAttribute('href').substring(1);
      const targetSection = document.getElementById(targetId);
      
      if (targetSection) {
        const yOffset = -80;
        const y = targetSection.getBoundingClientRect().top + window.pageYOffset + yOffset;
        window.scrollTo({ top: y, behavior: 'smooth' });
        
        navTabs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');
      }
    });
  });

  const navArrows = document.querySelectorAll('.mcp-nav-arrow');
  navArrows.forEach(arrow => {
    arrow.addEventListener('click', function() {
      const direction = this.dataset.scroll;
      const targetId = this.dataset.target;
      const carousel = document.getElementById(targetId);
      
      if (carousel) {
        const scrollAmount = carousel.offsetWidth * 0.8;
        const newScroll = direction === 'left' 
          ? carousel.scrollLeft - scrollAmount 
          : carousel.scrollLeft + scrollAmount;
        
        carousel.scrollTo({
          left: newScroll,
          behavior: 'smooth'
        });
      }
    });
  });

  document.addEventListener('click', async function(e) {
    const btn = e.target.closest('.mcp-add-to-cart');
    if (!btn || btn.disabled) return;

    e.preventDefault();
    e.stopPropagation();

    const variantId = btn.dataset.variantId;
    const productTitle = btn.dataset.productTitle;
    const game = btn.dataset.game;
    const card = btn.closest('.mcp-card') || btn.closest('.mcp-grid-card');

    if (!variantId || !game) return;

    const originalHTML = btn.innerHTML;
    btn.innerHTML = '<svg viewBox="0 0 24 24" style="width:18px;height:18px;fill:currentColor;animation:spin 1s linear infinite"><circle cx="12" cy="12" r="10" opacity="0.3"/></svg> Adding...';
    btn.disabled = true;

    try {
      if (window.GameCart && typeof window.GameCart.addToCart === 'function') {
        await window.GameCart.addToCart(game, variantId, 1, {});
      } else {
        const CART_STORAGE_KEY = 'game_carts';
        const carts = JSON.parse(localStorage.getItem(CART_STORAGE_KEY) || '{}');
        const gameCart = carts[game] || { items: [] };
        
        const existingItem = gameCart.items.find(item => item.id == variantId);
        if (existingItem) {
          existingItem.quantity += 1;
        } else {
          gameCart.items.push({ 
            id: parseInt(variantId), 
            quantity: 1,
            properties: {}
          });
        }
        
        carts[game] = gameCart;
        localStorage.setItem(CART_STORAGE_KEY, JSON.stringify(carts));

        await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            items: [{ id: variantId, quantity: 1 }],
            attributes: { game: game }
          })
        });
      }

      if(card){
        const rect = card.getBoundingClientRect();
        const x = (rect.left + rect.width / 2) / window.innerWidth;
        const y = (rect.top + rect.height / 2) / window.innerHeight;
        const colors = ['#FF6D00', '#2563EB', '#F59E0B', '#EC4899', '#10B981', '#8B5CF6'];
        
        confetti({
          particleCount: 55,
          spread: 360,
          origin: { x: x, y: y },
          colors: colors,
          startVelocity: 38,
          gravity: 0.7,
          scalar: 1.2,
          ticks: 130,
          decay: 0.9
        });
        
        setTimeout(() => {
          confetti({
            particleCount: 25,
            spread: 360,
            origin: { x: x, y: y },
            colors: ['#FFD700', '#FFF', '#FF6D00'],
            shapes: ['star'],
            startVelocity: 28,
            gravity: 0.5,
            scalar: 1,
            ticks: 110,
            decay: 0.92
          });
        }, 80);
        
        let celebration = card.querySelector('.mcp-cart-celebration');
        if(!celebration){
          celebration = document.createElement('div');
          celebration.className = 'mcp-cart-celebration';
          celebration.innerHTML = '<div class="mcp-cart-celebration-inner"><svg viewBox="0 0 24 24"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z"/></svg></div>';
          card.appendChild(celebration);
        }
        celebration.classList.remove('show', 'fade');
        void celebration.offsetWidth;
        celebration.classList.add('show');
        
        setTimeout(() => {
          confetti({
            particleCount: 35,
            spread: 360,
            origin: { x: x, y: y },
            colors: ['#2563EB', '#3B82F6', '#60A5FA', '#93C5FD', '#FFF'],
            startVelocity: 25,
            gravity: 0.8,
            scalar: 0.9,
            ticks: 80,
            decay: 0.92
          });
          celebration.classList.add('fade');
        }, 1500);
        
        setTimeout(() => { celebration.classList.remove('show', 'fade') }, 2100);
      }

      btn.innerHTML = '<svg viewBox="0 0 24 24" style="width:18px;height:18px;fill:currentColor"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z"/></svg> Added!';
      btn.style.background = '#16A34A';

      fetch('/cart.js')
        .then(r => r.json())
        .then(cart => {
          const countElements = document.querySelectorAll('[data-cart-count], .cart-count, #cart-count, cart-count');
          countElements.forEach(el => {
            el.textContent = cart.item_count;
            el.style.visibility = 'visible';
            el.style.opacity = '1';
          });
        });

      setTimeout(() => {
        btn.innerHTML = originalHTML;
        btn.style.background = '';
        btn.disabled = false;
      }, 2000);

    } catch (error) {
      console.error('Error adding to cart:', error);
      btn.innerHTML = '<svg viewBox="0 0 24 24" style="width:18px;height:18px;fill:currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg> Error';
      btn.style.background = '#DC2626';
      
      setTimeout(() => {
        btn.innerHTML = originalHTML;
        btn.style.background = '';
        btn.disabled = false;
      }, 2000);
    }
  });

  const sections = document.querySelectorAll('[data-section]');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const sectionId = entry.target.dataset.section;
        navTabs.forEach(tab => {
          if (tab.dataset.category === sectionId) {
            navTabs.forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
          }
        });
      }
    });
  }, { threshold: 0.3 });

  sections.forEach(section => observer.observe(section));

  const faqItems = document.querySelectorAll('.faq-item');
  faqItems.forEach(item => {
    const question = item.querySelector('.faq-question');
    if (question) {
      question.addEventListener('click', function() {
        faqItems.forEach(otherItem => {
          if (otherItem !== item) {
            otherItem.classList.remove('active');
          }
        });
        item.classList.toggle('active');
      });
    }
  });

})();

const style = document.createElement('style');
style.textContent = '@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }';
document.head.appendChild(style);
</script>

