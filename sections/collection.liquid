{% comment %} Render MM2 sections {% endcomment %}
{% if current_game == 'mm2' %}
  {% for section_data in mm2_sections %}
    {% assign parts = section_data | split: ":" %}
    {% assign handle = parts[0] %}
    {% assign icon = parts[1] %}
    {% assign title = parts[2] %}
    {% assign collection_handle = "mm2-" | append: handle %}
    {% assign section_collection = collections[collection_handle] %}
    
    {% if section_collection and section_collection.products.size > 0 %}
    <section class="mcp-section" id="{{ handle }}" data-section="{{ handle }}">
      <div class="mcp-section-header">
        <h2 class="mcp-section-title">
          <span class="mcp-section-icon">{{ icon }}</span>
          <span>{{ title }}</span>
        </h2>
        <div class="mcp-section-controls">
          <button class="mcp-nav-arrow" data-scroll="left" data-target="{{ handle }}-carousel">‹</button>
          <button class="mcp-nav-arrow" data-scroll="right" data-target="{{ handle }}-carousel">›</button>
        </div>
      </div>

      <div class="mcp-carousel-wrapper">
        <div class="mcp-carousel" id="{{ handle }}-carousel">
          {% for product in section_collection.products %}
            <div class="mcp-card">
              {% if product.compare_at_price > product.price and product.available %}
                {% assign savings = product.compare_at_price | minus: product.price %}
                <div class="mcp-save-badge">💰 Save {{ savings | money }}</div>
              {% endif %}
              {% unless product.available %}
                <div class="mcp-out-of-stock">🚫 Out of Stock</div>
              {% endunless %}
              <a href="{{ product.url }}">
                <div class="mcp-card-image-wrap">
                  {% if product.featured_image %}
                    <img class="mcp-card-image" src="{{ product.featured_image | img_url: '400x400' }}" alt="{{ product.title | escape }}" loading="lazy">
                  {% else %}
                    <div class="mcp-card-image" style="display: flex; align-items: center; justify-content: center; font-size: 48px; opacity: 0.3;">{{ icon }}</div>
                  {% endif %}
                  {% if product.vendor %}
                    <div class="mcp-vendor">🏷️ {{ product.vendor }}</div>
                  {% endif %}
                </div>
              </a>
              <div class="mcp-card-info">
                <h3 class="mcp-card-title">{{ product.title }}</h3>
                <div class="mcp-card-prices">
