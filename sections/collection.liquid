                     alt="{{ block.settings.title | default: 'Banner' }}"
                     style="object-position: {{ block.settings.image_position | default: 'center center' }};"
                     loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
              {% else %}
                <div class="mcp-banner-placeholder">🎮 Add a banner image in theme editor</div>
              {% endif %}
              
              {% if block.settings.title != blank or block.settings.subtitle != blank or block.settings.button_text != blank %}
                <div class="mcp-banner-overlay" style="
                  {% if block.settings.text_position == 'center' %}
                    justify-content: center; text-align: center; background: linear-gradient(0deg, rgba(0,0,0,0.4) 0%, transparent 100%);
                  {% elsif block.settings.text_position == 'right' %}
                    justify-content: flex-end; text-align: right; background: linear-gradient(270deg, rgba(0,0,0,0.4) 0%, transparent 60%);
                  {% else %}
                    justify-content: flex-start; text-align: left;
                  {% endif %}
                ">
                  <div class="mcp-banner-content">
                    {% if block.settings.title != blank %}
                      <h2 class="mcp-banner-title" style="color: {{ block.settings.text_color | default: '#FFFFFF' }};">
                        {{ block.settings.title }}
                      </h2>
                    {% endif %}
                    {% if block.settings.subtitle != blank %}
                      <p class="mcp-banner-subtitle" style="color: {{ block.settings.text_color | default: '#FFFFFF' }};">
                        {{ block.settings.subtitle }}
                      </p>
                    {% endif %}
                    {% if block.settings.button_text != blank %}
                      <a href="{{ block.settings.button_link }}" class="mcp-banner-btn" style="
                        background: {{ block.settings.button_bg | default: '#FFFFFF' }};
                        color: {{ block.settings.button_text_color | default: '#2563EB' }};
                      ">
                        {{ block.settings.button_text }}
                      </a>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
      
      {% assign banner_count = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'banner_slide' %}
